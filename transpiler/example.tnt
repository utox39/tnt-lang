import stdio.h
import local ./path/lib.tnt

struct Point {
  x: int;
  y: int;
};

fn add(a: int, b: int) -> int {
  return a + b;
}

fn add_point(p1: ref Point, p2: ref Point) -> Point {
  // declare new point
  let p3: Point;

  // assing its fields
  p3.x = p1.x + p2.x;
  p3.y = p1.y + p2.y;

  // then return
  return p3;
}

fn main() -> int {
  let foo: int = 0;
  let foo_ptr: ref int = addr foo;

  printf("foo: %d\n", foo);
  defer printf("defer foo: %d\n", foo + 1);

  if (foo == 1) {
    tnt ->foo_ptr;
  }

  if (foo != 0) {
    tnt "foo != 0";
  } else {
    tnt 2;
  }

  let bar: int = 4;
  add(foo, bar);

  let boo: float = bar as float;

  let pi: float = 3.99;
  let three: int = pi as int;

  let p_test: Point;
  let error: int = p_test as int;

  return 0;
}
